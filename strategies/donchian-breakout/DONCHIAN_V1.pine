//@version=5
// ============================================================================
//  DONCHIAN BREAKOUT V1
//  Research: Only classical strategy proven to beat B&H on BTC/crypto
//
//  LOGIC:
//  - Buy when price breaks above N-period high (momentum confirmed)
//  - Hold entire trend (no RSI exit, no early cuts)
//  - Exit when price breaks below M-period low (trend over)
//  - ATR-based position sizing (2% risk)
//  - ADX filter (only trade real trends, skip chop)
//
//  WHY DIFFERENT FROM QB V1:
//  - QB V1 exits too early (Supertrend flip)
//  - Donchian holds full trend from breakout to breakdown
//  - Fewer trades but much bigger avg win
//  - Proven in academic research to beat B&H on crypto
// ============================================================================

strategy("Donchian Breakout V1", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1, slippage=2, pyramiding=0, calc_on_every_tick=false, process_orders_on_close=true)

// ============================================================================
// INPUTS
// ============================================================================

// Donchian
entryPeriod = input.int(20, "Entry Period (High Breakout)", minval=5, maxval=100, group="Donchian")
exitPeriod = input.int(10, "Exit Period (Low Breakdown)", minval=3, maxval=50, group="Donchian")

// Trend filter
useADX = input.bool(true, "Use ADX Filter", group="Filters")
adxLength = input.int(14, "ADX Length", group="Filters")
adxThreshold = input.float(20, "ADX Min Threshold", minval=10, maxval=40, group="Filters")

// Volatility filter
useATRFilter = input.bool(true, "Use ATR Expansion Filter", group="Filters")
atrLength = input.int(14, "ATR Length", group="Filters")
atrMAPeriod = input.int(20, "ATR MA Period", group="Filters")

// Risk
riskPercent = input.float(5.0, "Risk % Per Trade", minval=0.5, maxval=10, step=0.5, group="Risk")
atrStopMultiplier = input.float(2.0, "ATR Stop Multiplier", minval=1.0, maxval=4.0, step=0.5, group="Risk")

// Direction
tradeDirection = input.string("Long Only", "Direction", options=["Long Only", "Long + Short"])

// Backtest window
startDate = input.time(timestamp("01 Jan 2023 00:00 +0000"), "Backtest Start", group="Backtest")
inDateRange = time >= startDate

// ============================================================================
// INDICATORS
// ============================================================================

// Donchian Channels
highestHigh = ta.highest(high, entryPeriod)
lowestLow = ta.lowest(low, exitPeriod)
shortHighest = ta.highest(high, exitPeriod)
shortLowest = ta.lowest(low, entryPeriod)

// Previous bar values for breakout detection
prevHighestHigh = highestHigh[1]
prevLowestLow = lowestLow[1]

// ADX
[diPlus, diMinus, adx] = ta.dmi(adxLength, adxLength)
adxOK = useADX ? adx > adxThreshold : true

// ATR expansion (volatility increasing = real move)
atr = ta.atr(atrLength)
atrMA = ta.sma(atr, atrMAPeriod)
atrExpanding = useATRFilter ? atr > atrMA : true

// ============================================================================
// SIGNALS
// ============================================================================

// Long: price closes above highest high of last N bars
longBreakout = close > prevHighestHigh and adxOK and atrExpanding and inDateRange

// Long exit: price closes below lowest low of last M bars (prior bar's channel — no lookahead)
longBreakdown = close < lowestLow[1]

// Short: price closes below lowest low of last N bars
shortBreakout = close < shortLowest[1] and adxOK and atrExpanding and inDateRange

// Short exit: price closes above highest high of last M bars (prior bar's channel — no lookahead)
shortBreakdown = close > shortHighest[1]

// ============================================================================
// POSITION SIZING
// ============================================================================

riskAmount = strategy.equity * (riskPercent / 100)
stopDistance = atr * atrStopMultiplier
positionSize = stopDistance > 0 ? math.min(riskAmount / stopDistance, strategy.equity * 0.95 / close) : 0

// ============================================================================
// EXECUTE
// ============================================================================

// Long entry
if longBreakout and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, qty=positionSize)

// Long exit
if strategy.position_size > 0
    if longBreakdown
        strategy.close("Long", comment="Breakdown")
    strategy.exit("Long Stop", "Long", stop=strategy.position_avg_price - stopDistance)

// Short entry
if (tradeDirection == "Long + Short") and shortBreakout and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, qty=positionSize)

// Short exit
if strategy.position_size < 0
    if shortBreakdown
        strategy.close("Short", comment="Breakdown")
    strategy.exit("Short Stop", "Short", stop=strategy.position_avg_price + stopDistance)

// ============================================================================
// VISUALS
// ============================================================================

// Donchian channels
plot(highestHigh, "Entry High", color=color.new(color.green, 40), linewidth=2)
plot(lowestLow, "Exit Low", color=color.new(color.red, 40), linewidth=2)
plot(ta.highest(high, math.round((entryPeriod + exitPeriod) / 2)), "Mid", color=color.new(color.gray, 60))

// Entry/exit markers
plotshape(longBreakout and strategy.position_size <= 0, "Long Break", shape.triangleup, location.belowbar, color.green, size=size.normal)
plotshape(longBreakdown and strategy.position_size > 0, "Long Exit", shape.triangledown, location.abovebar, color.red, size=size.small)

// ADX background
bgcolor(adxOK ? color.new(color.green, 97) : color.new(color.red, 97))

// Info table
var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(t, 1, 0, "Value", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(t, 0, 1, "ADX", text_color=color.white)
    table.cell(t, 1, 1, str.tostring(adx, "#.#"), text_color=adxOK ? color.green : color.red)
    table.cell(t, 0, 2, "ATR Exp", text_color=color.white)
    table.cell(t, 1, 2, atrExpanding ? "YES" : "NO", text_color=atrExpanding ? color.green : color.red)
    table.cell(t, 0, 3, "Entry Level", text_color=color.white)
    table.cell(t, 1, 3, str.tostring(highestHigh, "#.##"), text_color=color.white)
    table.cell(t, 0, 4, "Exit Level", text_color=color.white)
    table.cell(t, 1, 4, str.tostring(lowestLow, "#.##"), text_color=color.white)

// ============================================================================
// ALERTS
// ============================================================================
alertcondition(longBreakout, "Long Breakout", "Donchian LONG BREAKOUT {{ticker}} - Price broke above {{plot_0}}")
alertcondition(longBreakdown, "Long Breakdown", "Donchian EXIT LONG {{ticker}} - Price broke below {{plot_1}}")
alertcondition(shortBreakout, "Short Breakout", "Donchian SHORT BREAKOUT {{ticker}}")
