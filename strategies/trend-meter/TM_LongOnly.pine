//@version=5
strategy(
     title             = "TM Long Only — Final",
     shorttitle        = "TM Long Only",
     overlay           = true,
     initial_capital   = 10000,
     default_qty_type  = strategy.percent_of_equity,
     default_qty_value = 100,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.1,
     slippage          = 2
 )

// ═══════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════
emaBase  = input.int(13, "EMA base line", group="Trend Meter")
emaFast  = input.int(21, "EMA fast",      group="Trend Meter")
emaMed   = input.int(34, "EMA med",       group="Trend Meter")
emaSlow  = input.int(55, "EMA slow",      group="Trend Meter")
smoothK  = input.int(3,  "SmoothK",       group="Stochastic RSI")
smoothD  = input.int(3,  "SmoothD",       group="Stochastic RSI")
rsiLen   = input.int(14, "RSI length",    group="Stochastic RSI")
stochLen = input.int(14, "Stoch length",  group="Stochastic RSI")

// ═══════════════════════════════════════════════════════
// TREND METER BANDS
// ═══════════════════════════════════════════════════════
emaB = ta.ema(close, emaBase)
emaF = ta.ema(close, emaFast)
emaM = ta.ema(close, emaMed)
emaS = ta.ema(close, emaSlow)

band1Green    = emaB > emaF
band2Green    = emaF > emaM
band3Green    = emaM > emaS
allBandsGreen = band1Green and band2Green and band3Green

// ═══════════════════════════════════════════════════════
// STOCHASTIC RSI
// ═══════════════════════════════════════════════════════
rsiVal   = ta.rsi(close, rsiLen)
stochRaw = ta.stoch(rsiVal, rsiVal, rsiVal, stochLen)
K        = ta.ema(stochRaw, smoothK)
D        = ta.ema(K,        smoothD)

stochCrossUp = ta.crossover(K, D)

// ═══════════════════════════════════════════════════════
// ENTRY & EXIT — LONG ONLY
// ═══════════════════════════════════════════════════════
enterLong = allBandsGreen and stochCrossUp
exitLong  = not allBandsGreen and strategy.position_size > 0

if enterLong
    strategy.entry("Long", strategy.long)
if exitLong
    strategy.close("Long", comment="Bands flipped red")

// ═══════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════
plot(emaB, "EMA Base (13)", color=color.new(color.white,  50), linewidth=1)
plot(emaF, "EMA Fast (21)", color=color.new(color.green,  30), linewidth=1)
plot(emaM, "EMA Med  (34)", color=color.new(color.yellow, 30), linewidth=1)
plot(emaS, "EMA Slow (55)", color=color.new(color.red,    30), linewidth=2)

bgcolor(allBandsGreen ? color.new(color.green, 90) : na, title="All bands green")

plotshape(enterLong, title="BUY",
     style=shape.triangleup, location=location.belowbar,
     color=color.lime, size=size.small, text="BUY")

plotshape(exitLong, title="EXIT",
     style=shape.xcross, location=location.abovebar,
     color=color.orange, size=size.tiny, text="EXIT")

// ═══════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 5,
     bgcolor      = color.new(color.black, 60),
     border_color = color.new(color.gray,  40),
     border_width = 1,
     frame_color  = color.new(color.gray,  40),
     frame_width  = 1)

if barstate.islast
    table.cell(dash, 0, 0, "TM Long Only", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 40))
    table.cell(dash, 1, 0, "Status",       text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 40))
    table.cell(dash, 0, 1, "Band 1 (fast)", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, band1Green ? "GREEN" : "RED", text_color=band1Green ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 2, "Band 2 (med)",  text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, band2Green ? "GREEN" : "RED", text_color=band2Green ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 3, "Band 3 (slow)", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, band3Green ? "GREEN" : "RED", text_color=band3Green ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 4, "Signal",        text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, allBandsGreen and K > D ? "READY ✓" : allBandsGreen ? "WAIT CROSS" : "WAITING",
         text_color=allBandsGreen and K > D ? color.lime : color.gray, text_size=size.small)
