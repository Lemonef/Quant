//@version=5
// ============================================================================
//  QUANT BLEND V1 - Regime-Aware Strategy
//
//  RESEARCH-BASED DESIGN:
//  - Momentum + Mean Reversion blend (Sharpe 1.71, CAGR 56% per research)
//  - ADX regime detection (use right strategy per market state)
//  - Supertrend + RSI combo (research-proven, not Supertrend alone)
//  - Minimal parameters (anti-overfitting)
//  - Market-agnostic (stocks, forex, crypto, commodities, indices)
//
//  HOW IT WORKS:
//  1. Detect market regime via ADX
//     - ADX > 25 = TRENDING → Use momentum logic
//     - ADX < 20 = RANGING → Use mean reversion logic
//     - 20-25 = Transition zone, no new trades
//
//  2. In TRENDING regime: buy pullbacks in established trends
//     Entry: Supertrend green + price > 50 EMA + RSI 40-60 + cross above 50
//     Exit: Supertrend flips OR trend EMA break
//
//  3. In RANGING regime: buy oversold, sell overbought
//     Entry: Price touches lower Bollinger + RSI < 30
//     Exit: Price hits middle BB OR RSI > 70
//
//  4. Position sizing: 2% risk per trade (ATR-based)
// ============================================================================

strategy("Quant Blend V1 - Regime Aware", 
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ============================================================================
// INPUTS - Minimal set to avoid overfitting
// ============================================================================

// Direction
tradeDirection = input.string("Long Only", "Trade Direction", options=["Long Only", "Long + Short"])

// Regime detection
adxLength = input.int(14, "ADX Length", minval=5, maxval=30, group="Regime Detection")
adxTrendThreshold = input.float(25, "ADX Trend Threshold", minval=15, maxval=40, group="Regime Detection")
adxRangeThreshold = input.float(20, "ADX Range Threshold", minval=10, maxval=25, group="Regime Detection")

// Trend filter
emaTrend = input.int(50, "Trend EMA", minval=20, maxval=200, group="Trend")

// Supertrend (for momentum logic)
supertrendFactor = input.float(3.0, "Supertrend Factor", minval=1.0, maxval=5.0, step=0.5, group="Supertrend")
supertrendATR = input.int(10, "Supertrend ATR", minval=5, maxval=20, group="Supertrend")

// RSI (used by both regimes)
rsiLength = input.int(14, "RSI Length", group="RSI")
rsiTrendLow = input.float(40, "Momentum RSI Low", group="RSI")
rsiTrendHigh = input.float(60, "Momentum RSI High", group="RSI")
rsiOversold = input.float(30, "Oversold Level", group="RSI")
rsiOverbought = input.float(70, "Overbought Level", group="RSI")

// Bollinger Bands (for mean reversion)
bbLength = input.int(20, "BB Length", group="Bollinger")
bbMultiplier = input.float(2.0, "BB Std Dev", minval=1.0, maxval=3.0, step=0.1, group="Bollinger")

// Risk
atrLength = input.int(14, "ATR Length", group="Risk")
riskPercent = input.float(2.0, "Risk % Per Trade", minval=0.5, maxval=5.0, step=0.5, group="Risk")
atrStopMultiplier = input.float(2.0, "ATR Stop Multiplier", minval=1.0, maxval=4.0, step=0.5, group="Risk")

// ============================================================================
// INDICATORS
// ============================================================================

// ADX for regime
[diPlus, diMinus, adx] = ta.dmi(adxLength, adxLength)

// EMA trend filter
trendEma = ta.ema(close, emaTrend)

// Supertrend
[supertrend, supertrendDirection] = ta.supertrend(supertrendFactor, supertrendATR)
supertrendBullish = supertrendDirection < 0

// RSI
rsi = ta.rsi(close, rsiLength)

// Bollinger Bands
bbBasis = ta.sma(close, bbLength)
bbDev = bbMultiplier * ta.stdev(close, bbLength)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// ATR
atr = ta.atr(atrLength)

// ============================================================================
// REGIME DETECTION
// ============================================================================

trendingRegime = adx > adxTrendThreshold
rangingRegime = adx < adxRangeThreshold
transitionZone = adx >= adxRangeThreshold and adx <= adxTrendThreshold

// ============================================================================
// MOMENTUM SIGNALS (when trending)
// ============================================================================

momentumLongEntry = trendingRegime and close > trendEma and supertrendBullish and rsi >= rsiTrendLow and rsi <= rsiTrendHigh and ta.crossover(rsi, 50)

momentumShortEntry = trendingRegime and close < trendEma and not supertrendBullish and rsi <= (100 - rsiTrendLow) and rsi >= (100 - rsiTrendHigh) and ta.crossunder(rsi, 50)

momentumLongExit = not supertrendBullish or close < trendEma
momentumShortExit = supertrendBullish or close > trendEma

// ============================================================================
// MEAN REVERSION SIGNALS (when ranging)
// ============================================================================

reversionLongEntry = rangingRegime and close <= bbLower and rsi < rsiOversold and ta.crossover(close, bbLower)

reversionShortEntry = rangingRegime and close >= bbUpper and rsi > rsiOverbought and ta.crossunder(close, bbUpper)

reversionLongExit = close >= bbBasis or rsi > rsiOverbought
reversionShortExit = close <= bbBasis or rsi < rsiOversold

// ============================================================================
// COMBINED SIGNALS
// ============================================================================

longEntry = momentumLongEntry or reversionLongEntry
shortEntry = momentumShortEntry or reversionShortEntry

// ============================================================================
// POSITION SIZING (ATR-based, 2% risk)
// ============================================================================

riskAmount = strategy.equity * (riskPercent / 100)
stopDistance = atr * atrStopMultiplier
positionSize = stopDistance > 0 ? math.min(riskAmount / stopDistance, strategy.equity * 0.95 / close) : 0

// ============================================================================
// EXECUTE TRADES
// ============================================================================

// Long entries
if longEntry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, qty=positionSize)

// Short entries
if (tradeDirection == "Long + Short") and shortEntry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, qty=positionSize)

// Long exits (use right exit for entry regime)
if strategy.position_size > 0
    // If we're in trending regime, use momentum exit
    if trendingRegime and momentumLongExit
        strategy.close("Long", comment="Mom Exit")
    // If we're in ranging regime, use reversion exit
    if rangingRegime and reversionLongExit
        strategy.close("Long", comment="MR Exit")
    // Universal safety: hard ATR stop
    strategy.exit("Long Stop", "Long", stop=strategy.position_avg_price - (atr * atrStopMultiplier))

// Short exits
if strategy.position_size < 0
    if trendingRegime and momentumShortExit
        strategy.close("Short", comment="Mom Exit")
    if rangingRegime and reversionShortExit
        strategy.close("Short", comment="MR Exit")
    strategy.exit("Short Stop", "Short", stop=strategy.position_avg_price + (atr * atrStopMultiplier))

// ============================================================================
// VISUALS
// ============================================================================

// Plot trend EMA
plot(trendEma, "Trend EMA", color=close > trendEma ? color.new(color.green, 30) : color.new(color.red, 30), linewidth=2)

// Plot Bollinger Bands (only show when ranging)
plot(rangingRegime ? bbUpper : na, "BB Upper", color=color.new(color.blue, 50))
plot(rangingRegime ? bbLower : na, "BB Lower", color=color.new(color.blue, 50))
plot(rangingRegime ? bbBasis : na, "BB Basis", color=color.new(color.gray, 70))

// Plot Supertrend (only show when trending)
plot(trendingRegime ? supertrend : na, "Supertrend", color=supertrendBullish ? color.green : color.red, linewidth=2)

// Entry markers
plotshape(momentumLongEntry, "Mom Long", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small, text="M")
plotshape(reversionLongEntry, "MR Long", shape.circle, location.belowbar, color.new(color.lime, 0), size=size.small, text="R")
plotshape(momentumShortEntry, "Mom Short", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small, text="M")
plotshape(reversionShortEntry, "MR Short", shape.circle, location.abovebar, color.new(color.orange, 0), size=size.small, text="R")

// Background color shows current regime
bgcolor(trendingRegime ? color.new(color.green, 95) : rangingRegime ? color.new(color.blue, 95) : color.new(color.gray, 95))

// Info table
var table infoTable = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(infoTable, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(infoTable, 1, 0, "Value", text_color=color.white, bgcolor=color.new(color.blue, 50))
    table.cell(infoTable, 0, 1, "Regime", text_color=color.white)
    regimeText = trendingRegime ? "TRENDING" : rangingRegime ? "RANGING" : "TRANSITION"
    regimeColor = trendingRegime ? color.green : rangingRegime ? color.blue : color.gray
    table.cell(infoTable, 1, 1, regimeText, text_color=regimeColor)
    table.cell(infoTable, 0, 2, "ADX", text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(adx, "#.##"), text_color=color.white)
    table.cell(infoTable, 0, 3, "RSI", text_color=color.white)
    table.cell(infoTable, 1, 3, str.tostring(rsi, "#.##"), text_color=rsi > 70 ? color.red : rsi < 30 ? color.green : color.white)
    table.cell(infoTable, 0, 4, "Supertrend", text_color=color.white)
    table.cell(infoTable, 1, 4, supertrendBullish ? "BULL" : "BEAR", text_color=supertrendBullish ? color.green : color.red)
    table.cell(infoTable, 0, 5, "ATR%", text_color=color.white)
    table.cell(infoTable, 1, 5, str.tostring(atr/close*100, "#.##") + "%", text_color=color.white)
    table.cell(infoTable, 0, 6, "Position", text_color=color.white)
    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posColor = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(infoTable, 1, 6, posText, text_color=posColor)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(momentumLongEntry, "Momentum Long", "QB V1: MOMENTUM LONG on {{ticker}}")
alertcondition(reversionLongEntry, "Reversion Long", "QB V1: REVERSION LONG on {{ticker}}")
alertcondition(momentumShortEntry, "Momentum Short", "QB V1: MOMENTUM SHORT on {{ticker}}")
alertcondition(reversionShortEntry, "Reversion Short", "QB V1: REVERSION SHORT on {{ticker}}")
